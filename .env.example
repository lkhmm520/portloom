# Copy this file to .env and replace every value marked "change-me".
# Do not commit .env. The Compose files read the same file; each host only
# needs the variables for the service it runs.

TM_VERSION=local

# Server
TM_ADMIN_TOKEN=change-me-generate-a-long-random-value
TM_LISTEN_ADDR=127.0.0.1:8080
TM_GATEWAY_ADDR=127.0.0.1:8081
TM_DATABASE_PATH=/data/portloom.db
TM_SERVER_DATA_DIR=/opt/portloom/server

# Public edge listen addresses. Change the ports here to move the built-in
# ingress off 80/443 (e.g. :8080/:8443 behind a router port-forward). ACME
# HTTP-01 validation still requires public port 80 to reach TM_EDGE_HTTP_ADDR.
#TM_EDGE_HTTP_ADDR=:80
#TM_EDGE_HTTPS_ADDR=:443

# TCP/UDP route publication (stream edge). Enabled by default on 0.0.0.0;
# set to another literal IP to restrict the bind, or "off" to disable.
#TM_TCP_EDGE_BIND_HOST=0.0.0.0

# Agent control-plane identity
TM_SERVER_URL=https://tunnel-admin.example.com
# HTTPS is mandatory. For local development only, set this to true when
# TM_SERVER_URL uses http://localhost, http://127.0.0.0/8, or http://[::1].
TM_ALLOW_INSECURE_HTTP=false
TM_CLIENT_NAME=nas-home
TM_ENROLLMENT_TOKEN=change-me-create-in-the-web-ui
TM_AGENT_DATA_DIR=/opt/portloom/agent
TM_HEARTBEAT_INTERVAL=30s

# OpenSSH transport. Use a dedicated, restricted SSH account.
TM_SSH_HOST=tunnel.example.com
TM_SSH_PORT=22
TM_SSH_USER=tunnel
TM_SSH_PRIVATE_KEY_PATH=/opt/portloom/secrets/id_ed25519
TM_SSH_KNOWN_HOSTS_PATH=/opt/portloom/secrets/known_hosts
