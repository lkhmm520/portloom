PORTLOOM_AGENT_IMAGE=ghcr.io/lkhmm520/portloom-agent:latest
TM_SERVER_URL=https://portloom.example.com
TM_CLIENT_NAME=nas-home
TM_ENROLLMENT_TOKEN=change-me-create-once-in-console
TM_AGENT_DATA_DIR=./data/agent
TM_HEARTBEAT_INTERVAL=30s
TM_SSH_HOST=portloom.example.com
TM_SSH_PORT=2222
TM_SSH_USER=tunnel
TM_SSH_PRIVATE_KEY_PATH=./secrets/id_ed25519
TM_SSH_PUBLIC_KEY_PATH=./secrets/id_ed25519.pub
TM_SSH_KNOWN_HOSTS_PATH=./secrets/known_hosts

TM_MANAGED_SSH_ISOLATED=true
TM_MANAGED_SSH_READY_PATH=/data/managed-ssh.ready
