# PortLoom Server beginner template
# 1. Copy this file to .env in the same directory as compose.yml.
# 2. Replace the two REQUIRED values below.

# REQUIRED: the complete DNS hostname you chose for the PortLoom WebUI.
# An apex domain or any subdomain is valid; no portloom. prefix is required.
# Do not include https://, a port, or a path.
TM_PUBLIC_HOST=

# REQUIRED: use 64 hexadecimal characters so dotenv cannot reinterpret it.
# Generate one with: openssl rand -hex 32
TM_ADMIN_TOKEN=

# Optional: email used for ACME certificate notifications.
TM_ACME_EMAIL=

# Default public listeners. Public TCP 80, 443, and 2222 must reach this host.
TM_EDGE_HTTP_ADDR=:80
TM_EDGE_HTTPS_ADDR=:443
TM_MANAGED_SSH_PORT=2222

# TCP/UDP publishing: 0.0.0.0 enables it on every VPS address.
# Set this to off when you only need HTTP/HTTPS routes.
TM_TCP_EDGE_BIND_HOST=0.0.0.0

# Internal defaults. Most users do not need to edit these.
TM_LISTEN_ADDR=127.0.0.1:8080
TM_HEALTHCHECK_URL=http://127.0.0.1:8080/healthz
TM_GATEWAY_ADDR=127.0.0.1:8081
TM_MANAGED_SSH_ISOLATED=true
TM_TLS_ASK_ADDR=127.0.0.1:8082
TM_TLS_ASK_TOKEN=
