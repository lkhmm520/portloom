PORTLOOM_SERVER_IMAGE=ghcr.io/lkhmm520/portloom-server:latest
PORTLOOM_SSHD_IMAGE=ghcr.io/lkhmm520/portloom-sshd:latest
TM_ADMIN_TOKEN=change-me-use-openssl-rand-hex-32
TM_LISTEN_ADDR=127.0.0.1:8080
TM_GATEWAY_ADDR=127.0.0.1:8081
TM_SERVER_DATA_DIR=./data/server
TM_SSH_AUTH_DIR=./data/ssh-auth
TM_SSH_HOSTKEYS_DIR=./data/ssh-hostkeys
TM_MANAGED_SSH_PORT=2222
# Set TM_PUBLIC_HOST plus both edge addresses to let PortLoom own public HTTPS.
# When binding :80/:443, also add NET_BIND_SERVICE to the server service cap_add list.
TM_PUBLIC_HOST=
TM_EDGE_HTTP_ADDR=
TM_EDGE_HTTPS_ADDR=
TM_TLS_CACHE_DIR=/data/certs
TM_ACME_EMAIL=
# Legacy external Caddy integration only.
TM_TLS_ASK_TOKEN=

TM_MANAGED_SSH_ISOLATED=true
TM_TLS_ASK_ADDR=127.0.0.1:8082
