{
  "name": "portloom-docs",
  "private": true,
  "version": "0.1.0",
  "description": "Official bilingual documentation for PortLoom",
  "scripts": {
    "docs:sync-examples": "node scripts/sync-doc-examples.mjs",
    "docs:dev": "npm run docs:sync-examples && vitepress docs",
